{
  "name": "@verifier/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "verifier": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "eval": "node --import tsx src/eval/run.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "schema:generate": "node --import tsx ../../scripts/generate-verdict-schema.ts"
  },
  "dependencies": {
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "tsx": "^4.20.0"
  }
}
