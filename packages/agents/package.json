{
  "name": "@verifier/agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "eval": "node --import tsx src/eval/run.ts",
    "pretest": "pnpm --filter @verifier/core build",
    "test": "vitest run",
    "pretypecheck": "pnpm --filter @verifier/core build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@verifier/core": "workspace:*",
    "zod": "^3.25.0"
  }
}
