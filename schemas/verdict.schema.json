{
  "$id": "https://github.com/kaizen-agents-org/verifier/schemas/verdict.schema.json",
  "$ref": "#/definitions/Verdict",
  "definitions": {
    "Verdict": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "verdict": {
          "type": "string",
          "enum": [
            "open_pr",
            "open_pr_with_warning",
            "block_pr",
            "needs_context"
          ]
        },
        "final_verdict": {
          "type": "string",
          "enum": [
            "mergeable",
            "conditional",
            "not_mergeable",
            "inconclusive"
          ]
        },
        "must_fix": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "task",
                  "diff",
                  "verify_logs",
                  "builder_report",
                  "system"
                ]
              },
              "message": {
                "type": "string"
              },
              "evidence": {
                "type": "string"
              }
            },
            "required": [
              "source",
              "message"
            ],
            "additionalProperties": false
          }
        },
        "should_fix": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Verdict/properties/must_fix/items"
          }
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "summary": {
          "type": "string"
        },
        "run": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "started_at": {
              "type": "string"
            },
            "completed_at": {
              "type": "string"
            },
            "duration_ms": {
              "type": "integer",
              "minimum": 0
            },
            "workspace": {
              "type": "string"
            },
            "base_ref": {
              "type": "string"
            },
            "head_ref": {
              "type": "string"
            },
            "artifacts_dir": {
              "type": "string"
            },
            "changed_files": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "verify_commands": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "command": {
                    "type": "string"
                  },
                  "exit_code": {
                    "anyOf": [
                      {
                        "type": "integer"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "signal": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "duration_ms": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "timed_out": {
                    "type": "boolean"
                  },
                  "timeout_ms": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "required": [
                  "command",
                  "exit_code",
                  "signal",
                  "duration_ms"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": [
            "id",
            "started_at",
            "completed_at",
            "duration_ms",
            "workspace",
            "base_ref",
            "head_ref",
            "artifacts_dir",
            "changed_files",
            "verify_commands"
          ],
          "additionalProperties": false
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "intent",
                  "diff",
                  "verify_logs",
                  "builder_report",
                  "verdict",
                  "markdown"
                ]
              },
              "path": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "kind",
              "path",
              "summary"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "schemaVersion",
        "verdict",
        "must_fix",
        "should_fix",
        "confidence",
        "risk",
        "summary"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
