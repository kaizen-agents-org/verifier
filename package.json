{
  "name": "verifier",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "build": "pnpm -r build",
    "eval": "pnpm --filter @verifier/core eval",
    "eval:fixtures": "pnpm --filter @verifier/core eval:fixtures",
    "eval:semantic": "pnpm --filter @verifier/agents eval",
    "eval:semantic:ci": "node scripts/run-semantic-eval-ci.mjs",
    "test": "pnpm -r test",
    "test:package-entry": "pnpm --filter @verifier/probe-driver-api test:package-entry",
    "test:built-cli": "pnpm --filter @verifier/core test:built-cli",
    "pretypecheck": "pnpm --filter @verifier/probe-sdk build",
    "typecheck": "pnpm -r typecheck",
    "schema:generate": "pnpm --filter @verifier/core schema:generate",
    "schema:check": "pnpm schema:generate && git diff --exit-code -- schemas/verdict.schema.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "express": "^5.2.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.0"
  }
}
